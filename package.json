{
  "name": "move-reino-bible",
  "version": "0.1.0",
  "private": true,
  "description": "Move Reino Bible — plataforma bíblica com IA, RAG teológico e estudo profundo",
  "scripts": {
    "dev": "turbo run dev",
    "dev:desktop": "turbo run dev --filter=@mrb/desktop",
    "dev:api": "turbo run dev --filter=@mrb/api",
    "dev:web": "turbo run dev --filter=@mrb/web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "import:bible": "tsx scripts/import-bible.ts",
    "import:strongs": "tsx scripts/import-strongs.ts",
    "import:lexicon": "tsx scripts/import-lexicon.ts",
    "translate:strongs-kjv": "tsx scripts/translate-strongs-kjv.ts",
    "import:rag": "tsx scripts/import-rag.ts",
    "embed:rag": "tsx scripts/embed-rag.ts",
    "normalize:theology": "tsx scripts/normalize-theology-md.ts",
    "translate:theology": "tsx scripts/translate-theology-md.ts",
    "translate:theology:loop": "tsx scripts/translate-theology-loop.ts",
    "import:step": "tsx scripts/import-step.ts",
    "import:versification": "tsx scripts/import-versification.ts",
    "import:chains": "tsx scripts/import-chains.ts",
    "index:bibles": "tsx scripts/index-bibles.ts",
    "security:audit": "pnpm audit --audit-level=moderate"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "prisma": "^6.8.0",
    "tsx": "^4.19.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@mrb/bible-importers": "workspace:*",
    "@mrb/chain-system": "workspace:*",
    "@mrb/content-importers": "workspace:*",
    "@mrb/md-translator": "workspace:*",
    "@mrb/search-engine": "workspace:*",
    "@mrb/versification-engine": "workspace:*",
    "@prisma/client": "^6.8.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
